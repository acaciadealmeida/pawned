# Copy to .env for local builds. On Vercel, set these in Project → Settings → Environment Variables.

# Supabase (browser-safe public keys only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Slack webhook when someone sets a new high score
VITE_SLACK_WEBHOOK_URL=

# Production site origin, no trailing slash — used in index.html for og:image / twitter:image (link previews).
# Example: https://pawned.vercel.app
VITE_SITE_URL=
